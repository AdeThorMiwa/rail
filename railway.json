{
  "$schema": "https://railway.app/railway.schema.json",
  "deploy": {
    "startCommand": "cd api && ./mvnw clean package -DskipTests && java -jar target/*.jar",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowSeconds": 600
  },
  "build": {
    "builder": "dockerfile",
    "buildCommand": "cd api && ./mvnw clean package -DskipTests"
  }
}
