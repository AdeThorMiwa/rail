# -- Backend Env Vars --

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=https://your-app.com

# DeepSeek API key (get from platform.deepseek.com)
DEEPSEEK_API_KEY=

# JWT signing secret — must be ≥256 bits (32+ random chars)
JWT_SECRET=

# Google OAuth server client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=

# ── Database ─────────────────────────────────────────────────────────────────
# Defaults to localhost dev DB if not set
DB_URL=jdbc:postgresql://localhost:5432/rail
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=

# -- Frontend Env vars --
# 

API_BASE_URL=https://your-api-server.com
GOOGLE_SERVER_CLIENT_ID= # Same as above
AUTH_REFRESH_MAX_ATTEMPTS=2